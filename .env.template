# ============================================================================
# CONFIGURACIÓN DE VARIABLES DE ENTORNO - Beneficiary-Service
# ============================================================================

# INSTRUCCIONES:
# 1. Copia este archivo a .env
# 2. Actualiza los valores según tu entorno


# DATABASE CONFIGURATION - POSTGRESQL

# DB_HOST - DIRECCIÓN DEL SERVIDOR POSTGRES
DB_HOST=localhost

# DB_PORT - PUERTO DONDE POSTGRESQL ESCUCHA
DB_PORT=5432

# DB_USERNAME - USUARIO DE POSTGRESQL
DB_USERNAME=postgres

# DB_PASSWORD - CONTRASEÑA DEL USUARIO DE POSTGRESQL
DB_PASSWORD=password

# DB_DATABASE - NOMBRE DE LA BASE DE DATOS
DB_DATABASE=db_database

# DB_SCHEMA - Schema de PostgreSQL
# Define el "namespacio" donde están las tablas dentro de la base de datos.
DB_SCHEMA=schema

# DB_SYNCHRONIZE - Sincronización automática de esquema
# Si es TRUE: TypeORM sincroniza automáticamente la estructura de la base de datos
#             con las entidades de código (crea/modifica tablas automáticamente)
# Si es FALSE: NO sincroniza automáticamente. Necesita crear migraciones manuales para cambios
DB_SYNCHRONIZE=false


# MESSAGE BROKER - NATS

# NATS_SERVERS - URL del servidor NATS
# NATS es un bus de mensajes que permite comunicación asincrónica entre microservicios.
NATS_SERVERS="nats://localhost:4222"


# FTP CONFIGURATION - Almacenamiento de archivos

# PATH_FTP_FINGERPRINTS - Ruta FTP para huellas dactilares
# Ubicación en el servidor FTP donde se almacenan las imágenes de huellas
PATH_FTP_FINGERPRINTS="Person/Fingerprints"

# PATH_FTP_DOCUMENTS - Ruta FTP para documentos de afiliados
# Ubicación en el servidor FTP donde se almacenan documentos de afiliados
PATH_FTP_DOCUMENTS="Affiliate/Documents"

# PATH_FTP_FILE_DOSSIERS - Ruta FTP para expedientes
# Ubicación en el servidor FTP donde se almacenan expedientes completos
PATH_FTP_FILE_DOSSIERS="Affiliate/FileDossiers"

# PATH_FTP_IMPORT_DOCUMENTS_PVTBE - Ruta para importar documentos desde sistema externo
# Ruta donde se ubican documentos del sistema PVTBE para sincronización
PATH_FTP_IMPORT_DOCUMENTS_PVTBE="/documentos_pvtbe"